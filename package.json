{
  "name": "hearth",
  "version": "4.7.2",
  "description": "Hearth - P2P sesli sohbet, ekran ve dosya",
  "main": "main.js",
  "author": "Faruk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cesase/hearth.git"
  },
  "scripts": {
    "start": "electron .",
    "signal": "node signal-server/index.js",
    "dev": "electron .",
    "postinstall": "node scripts/patch-deps.js",
    "pack": "electron-builder --win portable --x64",
    "setup": "electron-builder --win nsis --x64",
    "dist": "electron-builder --win portable nsis --x64",
    "publish:win": "electron-builder --win nsis --x64 --publish always",
    "ui:smoke": "node tests/ui/smoke.spec.js",
    "ui:lab": "node tests/ui/smoke.spec.js --headed",
    "ui:scenario": "node tests/ui/run-scenario.js"
  },
  "build": {
    "appId": "com.hearth.app",
    "productName": "Hearth",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "main/**/*",
      "preload.js",
      "storage.js",
      "public/**/*",
      "assets/**/*",
      "cloud/**/*",
      "signal-server/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/uiohook-napi/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "cesase",
        "repo": "hearth",
        "releaseType": "release"
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup.${ext}",
      "signAndEditExecutable": false
    },
    "afterPack": "./scripts/afterPack-icon.js",
    "portable": {
      "artifactName": "Hearth-Portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Hearth",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "artifactName": "Hearth-Setup.exe",
      "deleteAppDataOnUninstall": false
    }
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "playwright": "^1.49.1",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "peer": "^1.0.2",
    "uiohook-napi": "^1.5.5",
    "ws": "^8.21.1"
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "uiohook-napi@1.5.5": true
  }
}
